# Database (auto-set by Railway when you add a PostgreSQL service)
DATABASE_URL=postgresql://user:password@localhost:5432/iowagrants

# AI PDF Parsing (required for PDF extraction)
ANTHROPIC_API_KEY=

# Optional: SAM.gov API key (get one at https://api.sam.gov)
SAM_GOV_API_KEY=

# Optional: Simpler Grants.gov API key
SIMPLER_GRANTS_API_KEY=

# Grants.gov API URL (default works without auth)
GRANTS_GOV_API_URL=https://api.grants.gov/v1/api/search2

# Optional: Airtable API key for grant database scrapers (Ladies Who Launch, etc.)
# Get a free Personal Access Token at https://airtable.com/create/tokens
# If not set, the scraper falls back to shared-view scraping (no auth needed)
AIRTABLE_API_KEY=

# Ladies Who Launch Airtable config (defaults are pre-filled)
LWL_AIRTABLE_BASE_ID=appWOyoayT1shujGM
LWL_AIRTABLE_TABLE_NAME=tbluTVoKAfaUQk6uG
LWL_AIRTABLE_VIEW_ID=shruHZuhBtjY8LY4I

# Optional: Brave Search API key (free tier: 2,000 queries/month)
BRAVE_SEARCH_API_KEY=

# Optional: SerpAPI key for Google search results (free tier: 100 searches/month)
SERPAPI_API_KEY=

# Optional: Google Custom Search API key + CX ID (free tier: 100 queries/day)
# Create at https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Secret to protect the /api/scraper endpoint (set to any random string)
CRON_SECRET=

# JWT secret for admin authentication (set to a random 32+ character string)
JWT_SECRET=

# Initial admin account (only needed for seeding the first admin)
ADMIN_EMAIL=russell.dale1@gmail.com
ADMIN_PASSWORD=
